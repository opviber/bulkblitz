datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  BUYER
  MANUFACTURER
  ADMIN
}

enum BatchStatus {
  DRAFT
  PENDING_APPROVAL
  LIVE
  CLOSED
  CANCELLED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum OrderStatus {
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum TxType {
  CREDIT
  DEBIT
}

enum KycStatus {
  UNSUBMITTED
  PENDING
  VERIFIED
  REJECTED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

enum NotificationChannel {
  WHATSAPP
  PUSH
  EMAIL
  SMS
}

model User {
  id            String                @id @default(uuid())
  phone         String                @unique
  email         String?               @unique
  name          String
  role          Role                  @default(BUYER)
  walletBalance Float                 @default(0.0)
  trustScore    Int                   @default(100)
  referralCode  String?               @unique
  referredById  String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  // Relationships
  manufacturer  Manufacturer?
  reservations  SlotReservation[]
  orders        Order[]
  transactions  BulkCashTransaction[]
  reviews       Review[]
  addresses     Address[]
  notifications Notification[]
  wishlists     Wishlist[]
  disputes      Dispute[]
  referredBy    User?                 @relation("Referrals", fields: [referredById], references: [id])
  referredUsers User[]                @relation("Referrals")
  referralsMade Referral[]            @relation("Referrer")
  referralFor   Referral?             @relation("Referred")
}

model Address {
  id        String   @id @default(uuid())
  userId    String
  type      String // e.g. "Home", "Office"
  street    String
  city      String
  state     String
  pin       String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Manufacturer {
  id              String   @id @default(uuid())
  userId          String   @unique
  businessName    String
  slug            String   @unique
  city            String
  state           String
  gstNumber       String?
  gstVerified     Boolean  @default(false)
  rating          Float    @default(5.0)
  yearsInBusiness Int      @default(0)
  blacklisted     Boolean  @default(false)
  createdAt       DateTime @default(now())

  // Relationships
  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  batches Batch[]
  kyc     ManufacturerKyc?
  payouts Payout[]
}

model ManufacturerKyc {
  id             String    @id @default(uuid())
  manufacturerId String    @unique
  status         KycStatus @default(UNSUBMITTED)
  gstNumber      String?
  panNumber      String?
  bankAccount    String?
  bankIfsc       String?
  pennyDropRef   String?
  reviewNote     String?
  submittedAt    DateTime?
  reviewedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  manufacturer Manufacturer @relation(fields: [manufacturerId], references: [id], onDelete: Cascade)
}

model Batch {
  id             String      @id @default(uuid())
  manufacturerId String
  title          String
  description    String
  images         String[] // Array of URLs
  category       String
  status         BatchStatus @default(DRAFT)
  moq            Int // Minimum Order Quantity slots
  maxSlots       Int // Maximum capacity slots
  currentSlots   Int         @default(0)
  finalPrice     Float? // Locked at close
  startTime      DateTime    @default(now())
  endTime        DateTime
  closedAt       DateTime?
  featured       Boolean     @default(false)
  approvedAt     DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Relationships
  manufacturer Manufacturer      @relation(fields: [manufacturerId], references: [id], onDelete: Cascade)
  tiers        TierSchedule[]
  reservations SlotReservation[]
  orders       Order[]
  wishlists    Wishlist[]

  @@index([status, endTime])
  @@index([category])
}

model TierSchedule {
  id       String @id @default(uuid())
  batchId  String
  minSlots Int
  maxSlots Int
  price    Float

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

model SlotReservation {
  id            String            @id @default(uuid())
  batchId       String
  userId        String
  quantity      Int               @default(1)
  status        ReservationStatus @default(PENDING)
  pricePerUnit  Float? // Tier price at reservation time
  holdAmount    Float? // Authorized hold amount
  paymentHoldId String? // Authorization ID from payment gateway (Razorpay)
  idempotencyKey String?          @unique
  joinedAt      DateTime          @default(now())

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([batchId, status])
}

model Order {
  id               String      @id @default(uuid())
  batchId          String
  userId           String
  quantity         Int
  pricePerUnit     Float
  totalAmount      Float
  paymentCaptureId String? // Captured payment ID from Razorpay
  status           OrderStatus @default(CONFIRMED)
  trackingNumber   String?
  carrier          String?
  orderedAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  batch    Batch     @relation(fields: [batchId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dispute  Dispute?
}

model BulkCashTransaction {
  id             String   @id @default(uuid())
  userId         String
  amount         Float
  type           TxType
  description    String
  idempotencyKey String?  @unique
  date           DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id             String   @id @default(uuid())
  userId         String
  manufacturerId String
  orderId        String?  @unique
  rating         Int      @default(5)
  comment        String?
  date           DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Referral {
  id           String   @id @default(uuid())
  referrerId   String
  referredId   String   @unique
  rewardAmount Float    @default(0)
  rewarded     Boolean  @default(false)
  createdAt    DateTime @default(now())

  referrer User @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred User @relation("Referred", fields: [referredId], references: [id], onDelete: Cascade)
}

model Dispute {
  id          String        @id @default(uuid())
  orderId     String        @unique
  userId      String
  reason      String
  description String?
  evidence    String[]
  status      DisputeStatus @default(OPEN)
  resolution  String?
  createdAt   DateTime      @default(now())
  resolvedAt  DateTime?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String              @id @default(uuid())
  userId    String
  channel   NotificationChannel
  title     String
  body      String
  link      String?
  read      Boolean             @default(false)
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  batchId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([userId, batchId])
}

model PickupPoint {
  id        String   @id @default(uuid())
  name      String
  ownerName String
  phone     String
  street    String
  city      String
  state     String
  pin       String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Payout {
  id             String       @id @default(uuid())
  manufacturerId String
  amount         Float
  status         PayoutStatus @default(PENDING)
  reference      String?
  batchId        String?
  createdAt      DateTime     @default(now())
  paidAt         DateTime?

  manufacturer Manufacturer @relation(fields: [manufacturerId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
}

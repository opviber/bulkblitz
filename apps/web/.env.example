# ── Database (Supabase Postgres) ──────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# ── Supabase Auth + Realtime ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"   # server only — never expose

# ── Razorpay (authorize → capture → refund) ──────────────────────────────────
RAZORPAY_KEY_ID="rzp_live_or_test_key"
RAZORPAY_KEY_SECRET="your-secret"
RAZORPAY_WEBHOOK_SECRET="your-webhook-secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_live_or_test_key"  # client checkout

# ── Cron protection ───────────────────────────────────────────────────────────
CRON_SECRET="generate-a-long-random-string"

# ── Rate limiting (optional, Upstash Redis) ──────────────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Notifications (optional providers) ────────────────────────────────────────
# WhatsApp (MSG91 / Gupshup), FCM, Resend/SES — wire in lib/notifications.js
MSG91_AUTH_KEY=""
FCM_SERVER_KEY=""
RESEND_API_KEY=""

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL="https://bulkblitz.in"

# ── Dev only: fall back to a seeded user when Supabase isn't configured ───────
# DEV_FALLBACK_USER="<a User id from the seed>"
